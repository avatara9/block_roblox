#Requires -Version 5.1
<#
.SYNOPSIS
    Complete Roblox blocking for Windows 10.

.DESCRIPTION
    1. Finds Roblox executable files for all local users.
    2. Creates outbound blocking rules in Windows Defender Firewall.
    3. Blocks the packaged Microsoft Store version of Roblox.
    4. Blocks roblox.com and rbxcdn.com in Microsoft Edge and Google Chrome.
    5. Blocks the same domains in Mozilla Firefox through policies.json.
    6. Creates a system task that checks for new Roblox versions every hour.

.PARAMETER RefreshOnly
    Internal refresh mode used by Task Scheduler.

.PARAMETER Uninstall
    Removes the rules, policies, and scheduled task created by this script.

.EXAMPLE
    powershell.exe -ExecutionPolicy Bypass -File .\Block-Roblox-All.ps1

.EXAMPLE
    powershell.exe -ExecutionPolicy Bypass -File .\Block-Roblox-All.ps1 -Uninstall
#>

[CmdletBinding()]
param(
    [switch]$RefreshOnly,
    [switch]$Uninstall
)

Set-StrictMode -Version 2.0
$ErrorActionPreference = 'Stop'

$InstallDirectory = Join-Path $env:ProgramData 'RobloxBlock'
$InstalledScript  = Join-Path $InstallDirectory 'Block-Roblox-All.ps1'
$LogFile          = Join-Path $InstallDirectory 'RobloxBlock.log'
$TaskName         = 'RobloxBlock-AutoRefresh'
$FirewallGroup    = 'RobloxBlock'
$RulePrefix       = 'RBX-BLOCK-'

# A single domain entry covers the domain and all of its subdomains
# in the Chromium URLBlocklist.
$BlockedChromiumUrls = @(
    'roblox.com',
    'rbxcdn.com'
)

$BlockedFirefoxUrls = @(
    '*://roblox.com/*',
    '*://*.roblox.com/*',
    '*://rbxcdn.com/*',
    '*://*.rbxcdn.com/*'
)

function Test-IsAdministrator {
    $identity = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = New-Object Security.Principal.WindowsPrincipal($identity)
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

function Restart-Elevated {
    if ([string]::IsNullOrWhiteSpace($PSCommandPath)) {
        throw 'The script path could not be determined.'
    }

    $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    if ($RefreshOnly) { $arguments += ' -RefreshOnly' }
    if ($Uninstall)   { $arguments += ' -Uninstall' }

    Start-Process -FilePath "$env:SystemRoot\System32\WindowsPowerShell\v1.0\powershell.exe" `
        -ArgumentList $arguments -Verb RunAs
    exit
}

if (-not (Test-IsAdministrator)) {
    Restart-Elevated
}

New-Item -Path $InstallDirectory -ItemType Directory -Force | Out-Null

if (Test-Path $LogFile) {
    try {
        if ((Get-Item $LogFile).Length -gt 2MB) {
            Get-Content $LogFile -Tail 500 | Set-Content $LogFile -Encoding UTF8
        }
    }
    catch {
        # A log maintenance error must not stop the blocking process.
    }
}

function Write-Log {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Message,

        [ValidateSet('INFO', 'WARN', 'ERROR')]
        [string]$Level = 'INFO'
    )

    $line = '{0:yyyy-MM-dd HH:mm:ss} [{1}] {2}' -f (Get-Date), $Level, $Message
    try {
        Add-Content -Path $LogFile -Value $line -Encoding UTF8
    }
    catch {
        # Do not stop the main operation because of a logging error.
    }

    if (-not $RefreshOnly) {
        switch ($Level) {
            'WARN'  { Write-Host $line -ForegroundColor Yellow }
            'ERROR' { Write-Host $line -ForegroundColor Red }
            default { Write-Host $line }
        }
    }
}

function Get-StableId {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Text
    )

    $md5 = [Security.Cryptography.MD5]::Create()
    try {
        $bytes = [Text.Encoding]::UTF8.GetBytes($Text.ToLowerInvariant())
        return -join ($md5.ComputeHash($bytes) | ForEach-Object { $_.ToString('x2') })
    }
    finally {
        $md5.Dispose()
    }
}

function Get-LocalProfilePaths {
    $paths = New-Object System.Collections.Generic.List[string]

    if ($env:USERPROFILE) {
        $paths.Add($env:USERPROFILE)
    }

    $profileList = 'HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\ProfileList'
    if (Test-Path $profileList) {
        Get-ChildItem $profileList -ErrorAction SilentlyContinue | ForEach-Object {
            try {
                $rawPath = (Get-ItemProperty $_.PSPath -Name ProfileImagePath).ProfileImagePath
                $expandedPath = [Environment]::ExpandEnvironmentVariables([string]$rawPath)
                if ($expandedPath) {
                    $paths.Add($expandedPath)
                }
            }
            catch {
                # Skip corrupted profile entries.
            }
        }
    }

    if (Test-Path "$env:SystemDrive\Users") {
        Get-ChildItem "$env:SystemDrive\Users" -Directory -Force -ErrorAction SilentlyContinue |
            ForEach-Object { $paths.Add($_.FullName) }
    }

    return $paths |
        Where-Object { $_ -and (Test-Path $_) } |
        Sort-Object -Unique
}

function Get-RobloxExecutablePaths {
    $roots = New-Object System.Collections.Generic.List[string]

    if ($env:ProgramFiles) {
        $roots.Add((Join-Path $env:ProgramFiles 'Roblox'))
    }

    ${programFilesX86} = ${env:ProgramFiles(x86)}
    if (${programFilesX86}) {
        $roots.Add((Join-Path ${programFilesX86} 'Roblox'))
    }

    $roots.Add((Join-Path $env:ProgramData 'Roblox'))

    foreach ($profilePath in (Get-LocalProfilePaths)) {
        $roots.Add((Join-Path $profilePath 'AppData\Local\Roblox'))
    }

    # Also inspect paths stored in application uninstall entries.
    $uninstallRoots = @(
        'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall',
        'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'
    )

    foreach ($uninstallRoot in $uninstallRoots) {
        if (-not (Test-Path $uninstallRoot)) { continue }

        Get-ChildItem $uninstallRoot -ErrorAction SilentlyContinue | ForEach-Object {
            try {
                $app = Get-ItemProperty $_.PSPath
                if ([string]$app.DisplayName -match '(?i)roblox' -and $app.InstallLocation) {
                    $roots.Add([Environment]::ExpandEnvironmentVariables([string]$app.InstallLocation))
                }
            }
            catch {
                # Skip invalid entries.
            }
        }
    }

    $files = New-Object System.Collections.Generic.List[string]

    foreach ($root in ($roots | Sort-Object -Unique)) {
        if (-not $root -or -not (Test-Path $root)) { continue }

        try {
            Get-ChildItem -Path $root -Filter '*.exe' -File -Recurse -Force `
                -ErrorAction SilentlyContinue | ForEach-Object {
                    $files.Add($_.FullName)
                }
        }
        catch {
            Write-Log "The directory could not be scanned completely: $root. $($_.Exception.Message)" 'WARN'
        }
    }

    # If Roblox is running from a nonstandard directory, add the process path.
    Get-Process -ErrorAction SilentlyContinue | ForEach-Object {
        try {
            $processPath = $_.Path
            if ($processPath -and (
                $_.ProcessName -match '(?i)^roblox' -or
                $processPath -match '(?i)[\\/]roblox[\\/]'
            )) {
                $files.Add($processPath)
            }
        }
        catch {
            # Access may be denied for some system processes.
        }
    }

    return $files |
        Where-Object { $_ -and (Test-Path $_ -PathType Leaf) } |
        Sort-Object -Unique
}

function Add-ProgramBlockRule {
    param(
        [Parameter(Mandatory = $true)]
        [string]$ProgramPath
    )

    $id = Get-StableId -Text $ProgramPath
    $ruleName = "$RulePrefix" + 'PROGRAM-' + $id

    if (Get-NetFirewallRule -Name $ruleName -ErrorAction SilentlyContinue) {
        return $false
    }

    $displayName = 'BLOCK ROBLOX — ' + [IO.Path]::GetFileName($ProgramPath)

    New-NetFirewallRule `
        -Name $ruleName `
        -DisplayName $displayName `
        -Description "Blocks outbound Roblox Internet access: $ProgramPath" `
        -Group $FirewallGroup `
        -Direction Outbound `
        -Program $ProgramPath `
        -Action Block `
        -Profile Any `
        -Enabled True | Out-Null

    Write-Log "Created a firewall rule for file: $ProgramPath"
    return $true
}

function Initialize-AppContainerSidHelper {
    if ($null -ne ('RobloxBlock.AppContainerSid' -as [type])) {
        return
    }

    $source = @'
using System;
using System.Runtime.InteropServices;
using System.Security.Principal;

namespace RobloxBlock
{
    public static class AppContainerSid
    {
        [DllImport("userenv.dll", CharSet = CharSet.Unicode)]
        private static extern int DeriveAppContainerSidFromAppContainerName(
            string appContainerName,
            out IntPtr sid);

        [DllImport("advapi32.dll", SetLastError = true)]
        private static extern IntPtr FreeSid(IntPtr sid);

        public static string FromPackageFamilyName(string packageFamilyName)
        {
            IntPtr sidPointer;
            int result = DeriveAppContainerSidFromAppContainerName(
                packageFamilyName,
                out sidPointer);

            if (result != 0)
            {
                Marshal.ThrowExceptionForHR(result);
            }

            try
            {
                return new SecurityIdentifier(sidPointer).Value;
            }
            finally
            {
                FreeSid(sidPointer);
            }
        }
    }
}
'@

    Add-Type -TypeDefinition $source -Language CSharp
}

function Add-StorePackageBlockRules {
    $added = 0

    try {
        Import-Module Appx -ErrorAction Stop
        $packages = Get-AppxPackage -AllUsers -ErrorAction Stop |
            Where-Object {
                [string]$_.Name -match '(?i)roblox' -or
                [string]$_.PackageFullName -match '(?i)roblox' -or
                [string]$_.PackageFamilyName -match '(?i)roblox'
            } |
            Sort-Object PackageFamilyName -Unique
    }
    catch {
        Write-Log "Failed to retrieve the list of Microsoft Store applications: $($_.Exception.Message)" 'WARN'
        return 0
    }

    if (-not $packages) {
        return 0
    }

    try {
        Initialize-AppContainerSidHelper
    }
    catch {
        Write-Log "Failed to initialize packaged-application SID processing: $($_.Exception.Message)" 'WARN'
        return 0
    }

    foreach ($package in $packages) {
        try {
            $packageSid = [RobloxBlock.AppContainerSid]::FromPackageFamilyName(
                [string]$package.PackageFamilyName
            )

            $id = Get-StableId -Text $packageSid
            $ruleName = "$RulePrefix" + 'PACKAGE-' + $id

            if (Get-NetFirewallRule -Name $ruleName -ErrorAction SilentlyContinue) {
                continue
            }

            New-NetFirewallRule `
                -Name $ruleName `
                -DisplayName "BLOCK ROBLOX — Microsoft Store ($($package.Name))" `
                -Description "Blocks the packaged Roblox version: $($package.PackageFamilyName)" `
                -Group $FirewallGroup `
                -Direction Outbound `
                -Package $packageSid `
                -Action Block `
                -Profile Any `
                -Enabled True | Out-Null

            $added++
            Write-Log "Created a firewall rule for Microsoft Store package: $($package.PackageFamilyName)"
        }
        catch {
            Write-Log "Failed to create a rule for package $($package.PackageFamilyName): $($_.Exception.Message)" 'WARN'
        }
    }

    return $added
}

function Add-RegistryListValues {
    param(
        [Parameter(Mandatory = $true)]
        [string]$RegistryPath,

        [Parameter(Mandatory = $true)]
        [string[]]$Values
    )

    New-Item -Path $RegistryPath -Force | Out-Null
    $registryKey = Get-Item $RegistryPath

    $valueNames = @($registryKey.GetValueNames() | Where-Object { $_ })
    $existingValues = @(
        $valueNames | ForEach-Object { [string]$registryKey.GetValue($_) }
    )

    foreach ($value in $Values) {
        if ($existingValues -contains $value) {
            continue
        }

        $index = 1
        while ($valueNames -contains [string]$index) {
            $index++
        }

        New-ItemProperty `
            -Path $RegistryPath `
            -Name ([string]$index) `
            -Value $value `
            -PropertyType String `
            -Force | Out-Null

        $valueNames += [string]$index
        $existingValues += $value
        Write-Log "Added browser policy: $RegistryPath = $value"
    }
}

function Remove-RegistryListValues {
    param(
        [Parameter(Mandatory = $true)]
        [string]$RegistryPath,

        [Parameter(Mandatory = $true)]
        [string[]]$Values
    )

    if (-not (Test-Path $RegistryPath)) {
        return
    }

    $registryKey = Get-Item $RegistryPath

    foreach ($valueName in @($registryKey.GetValueNames() | Where-Object { $_ })) {
        $currentValue = [string]$registryKey.GetValue($valueName)
        if ($Values -contains $currentValue) {
            Remove-ItemProperty -Path $RegistryPath -Name $valueName -Force
        }
    }
}

function Get-FirefoxInstallDirectories {
    $directories = New-Object System.Collections.Generic.List[string]

    if ($env:ProgramFiles) {
        $directories.Add((Join-Path $env:ProgramFiles 'Mozilla Firefox'))
    }

    ${programFilesX86} = ${env:ProgramFiles(x86)}
    if (${programFilesX86}) {
        $directories.Add((Join-Path ${programFilesX86} 'Mozilla Firefox'))
    }

    $uninstallRoots = @(
        'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall',
        'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'
    )

    foreach ($uninstallRoot in $uninstallRoots) {
        if (-not (Test-Path $uninstallRoot)) { continue }

        Get-ChildItem $uninstallRoot -ErrorAction SilentlyContinue | ForEach-Object {
            try {
                $app = Get-ItemProperty $_.PSPath
                if ([string]$app.DisplayName -match '(?i)mozilla firefox' -and $app.InstallLocation) {
                    $directories.Add([Environment]::ExpandEnvironmentVariables(
                        [string]$app.InstallLocation
                    ))
                }
            }
            catch {
                # Skip invalid entries.
            }
        }
    }

    return $directories |
        Where-Object {
            $_ -and
            (Test-Path $_) -and
            (Test-Path (Join-Path $_ 'firefox.exe'))
        } |
        Sort-Object -Unique
}

function Set-FirefoxBlockPolicy {
    param(
        [Parameter(Mandatory = $true)]
        [string]$FirefoxDirectory,

        [switch]$Remove
    )

    $distributionDirectory = Join-Path $FirefoxDirectory 'distribution'
    $policyFile = Join-Path $distributionDirectory 'policies.json'

    if ($Remove -and -not (Test-Path $policyFile)) {
        return
    }

    if (-not $Remove) {
        New-Item -Path $distributionDirectory -ItemType Directory -Force | Out-Null
    }

    $configuration = $null

    if (Test-Path $policyFile) {
        try {
            $configuration = Get-Content $policyFile -Raw -Encoding UTF8 | ConvertFrom-Json
        }
        catch {
            Write-Log "Firefox policies.json contains invalid JSON and was left unchanged: $policyFile" 'WARN'
            return
        }
    }

    if ($null -eq $configuration) {
        $configuration = [pscustomobject]@{}
    }

    if ($null -eq $configuration.PSObject.Properties['policies']) {
        $configuration | Add-Member -NotePropertyName policies `
            -NotePropertyValue ([pscustomobject]@{})
    }
    elseif ($null -eq $configuration.policies) {
        $configuration.policies = [pscustomobject]@{}
    }

    if ($null -eq $configuration.policies.PSObject.Properties['WebsiteFilter']) {
        $configuration.policies | Add-Member -NotePropertyName WebsiteFilter `
            -NotePropertyValue ([pscustomobject]@{})
    }
    elseif ($null -eq $configuration.policies.WebsiteFilter) {
        $configuration.policies.WebsiteFilter = [pscustomobject]@{}
    }

    $websiteFilter = $configuration.policies.WebsiteFilter
    $currentBlocks = @()

    if ($null -ne $websiteFilter.PSObject.Properties['Block']) {
        $currentBlocks = @($websiteFilter.Block) |
            Where-Object { -not [string]::IsNullOrWhiteSpace([string]$_) }
    }

    if ($Remove) {
        $newBlocks = @(
            $currentBlocks |
                Where-Object { $BlockedFirefoxUrls -notcontains [string]$_ } |
                Sort-Object -Unique
        )
    }
    else {
        $newBlocks = @(
            @($currentBlocks + $BlockedFirefoxUrls) |
                Where-Object { -not [string]::IsNullOrWhiteSpace([string]$_) } |
                Sort-Object -Unique
        )
    }

    if ($null -eq $websiteFilter.PSObject.Properties['Block']) {
        $websiteFilter | Add-Member -NotePropertyName Block -NotePropertyValue $newBlocks
    }
    else {
        $websiteFilter.Block = $newBlocks
    }

    if ((Test-Path $policyFile) -and -not (Test-Path "$policyFile.robloxblock.bak")) {
        Copy-Item $policyFile "$policyFile.robloxblock.bak" -Force
    }

    $configuration |
        ConvertTo-Json -Depth 30 |
        Set-Content -Path $policyFile -Encoding UTF8

    if ($Remove) {
        Write-Log "Removed Roblox rules from Firefox: $policyFile"
    }
    else {
        Write-Log "Configured Roblox blocking in Firefox: $policyFile"
    }
}

function Install-AutoRefreshTask {
    if (-not (Test-Path $InstalledScript)) {
        throw "The installed script copy was not found: $InstalledScript"
    }

    Import-Module ScheduledTasks -ErrorAction Stop

    $powerShellPath = "$env:SystemRoot\System32\WindowsPowerShell\v1.0\powershell.exe"
    $actionArguments = "-NoProfile -NonInteractive -ExecutionPolicy Bypass -File `"$InstalledScript`" -RefreshOnly"

    $action = New-ScheduledTaskAction `
        -Execute $powerShellPath `
        -Argument $actionArguments

    $startupTrigger = New-ScheduledTaskTrigger -AtStartup

    # Repeat every 60 minutes. A ten-year duration effectively provides
    # continuous checking for a home computer.
    $hourlyTrigger = New-ScheduledTaskTrigger `
        -Once `
        -At (Get-Date).AddMinutes(5) `
        -RepetitionInterval (New-TimeSpan -Hours 1) `
        -RepetitionDuration (New-TimeSpan -Days 3650)

    $principal = New-ScheduledTaskPrincipal `
        -UserId 'SYSTEM' `
        -LogonType ServiceAccount `
        -RunLevel Highest

    $settings = New-ScheduledTaskSettingsSet `
        -AllowStartIfOnBatteries `
        -DontStopIfGoingOnBatteries `
        -StartWhenAvailable `
        -ExecutionTimeLimit (New-TimeSpan -Minutes 15)

    Register-ScheduledTask `
        -TaskName $TaskName `
        -Action $action `
        -Trigger @($startupTrigger, $hourlyTrigger) `
        -Principal $principal `
        -Settings $settings `
        -Description 'Finds new Roblox versions and blocks them in Windows Firewall.' `
        -Force | Out-Null

    Write-Log "Created scheduled task: $TaskName"
}

function Remove-RobloxBlock {
    Write-Log 'Started removing Roblox blocking.'

    try {
        Get-NetFirewallRule -Group $FirewallGroup -ErrorAction SilentlyContinue |
            Remove-NetFirewallRule -ErrorAction SilentlyContinue
        Write-Log 'Removed Windows Firewall rules.'
    }
    catch {
        Write-Log "Failed to remove Windows Firewall rules: $($_.Exception.Message)" 'WARN'
    }

    Remove-RegistryListValues `
        -RegistryPath 'HKLM:\SOFTWARE\Policies\Microsoft\Edge\URLBlocklist' `
        -Values $BlockedChromiumUrls

    Remove-RegistryListValues `
        -RegistryPath 'HKLM:\SOFTWARE\Policies\Google\Chrome\URLBlocklist' `
        -Values $BlockedChromiumUrls

    foreach ($firefoxDirectory in (Get-FirefoxInstallDirectories)) {
        try {
            Set-FirefoxBlockPolicy -FirefoxDirectory $firefoxDirectory -Remove
        }
        catch {
            Write-Log "Failed to update Firefox: $($_.Exception.Message)" 'WARN'
        }
    }

    try {
        Unregister-ScheduledTask -TaskName $TaskName -Confirm:$false `
            -ErrorAction SilentlyContinue
        Write-Log 'Removed the automatic refresh task.'
    }
    catch {
        Write-Log "Failed to remove the scheduled task: $($_.Exception.Message)" 'WARN'
    }

    Write-Host ''
    Write-Host 'Roblox blocking has been removed.' -ForegroundColor Green
    Write-Host 'Completely restart all browsers.' -ForegroundColor Yellow
}

if ($Uninstall) {
    Remove-RobloxBlock
    exit
}

# Save the working copy in ProgramData. Task Scheduler will run this copy.
if (-not $RefreshOnly) {
    if ([string]::IsNullOrWhiteSpace($PSCommandPath)) {
        throw 'The current script path could not be determined.'
    }

    if (-not [string]::Equals(
        [IO.Path]::GetFullPath($PSCommandPath),
        [IO.Path]::GetFullPath($InstalledScript),
        [StringComparison]::OrdinalIgnoreCase
    )) {
        Copy-Item -Path $PSCommandPath -Destination $InstalledScript -Force
        Write-Log "The script was installed to: $InstalledScript"
    }
}

try {
    Import-Module NetSecurity -ErrorAction Stop
}
catch {
    throw "Failed to load the Windows Firewall NetSecurity module: $($_.Exception.Message)"
}

$programRuleCount = 0
$executables = @(Get-RobloxExecutablePaths)

foreach ($executable in $executables) {
    try {
        if (Add-ProgramBlockRule -ProgramPath $executable) {
            $programRuleCount++
        }
    }
    catch {
        Write-Log "Failed to create a rule for $executable`: $($_.Exception.Message)" 'WARN'
    }
}

$packageRuleCount = Add-StorePackageBlockRules

Add-RegistryListValues `
    -RegistryPath 'HKLM:\SOFTWARE\Policies\Microsoft\Edge\URLBlocklist' `
    -Values $BlockedChromiumUrls

Add-RegistryListValues `
    -RegistryPath 'HKLM:\SOFTWARE\Policies\Google\Chrome\URLBlocklist' `
    -Values $BlockedChromiumUrls

foreach ($firefoxDirectory in (Get-FirefoxInstallDirectories)) {
    try {
        Set-FirefoxBlockPolicy -FirefoxDirectory $firefoxDirectory
    }
    catch {
        Write-Log "Failed to configure Firefox in $firefoxDirectory`: $($_.Exception.Message)" 'WARN'
    }
}

if (-not $RefreshOnly) {
    try {
        Install-AutoRefreshTask
    }
    catch {
        Write-Log "Failed to create the automatic refresh task: $($_.Exception.Message)" 'WARN'
    }
}

$disabledProfiles = @(
    Get-NetFirewallProfile -ErrorAction SilentlyContinue |
        Where-Object { $_.Enabled -eq $false } |
        Select-Object -ExpandProperty Name
)

if ($disabledProfiles.Count -gt 0) {
    Write-Log "Windows Firewall is disabled for the following profiles: $($disabledProfiles -join ', '). The rules will not take effect while the firewall is disabled." 'WARN'
}

Write-Log "Check completed. EXE files found: $($executables.Count); new file rules: $programRuleCount; new package rules: $packageRuleCount."

if (-not $RefreshOnly) {
    Write-Host ''
    Write-Host 'Roblox blocking has been installed.' -ForegroundColor Green
    Write-Host "Roblox executable files found: $($executables.Count)"
    Write-Host "Log: $LogFile"
    Write-Host ''
    Write-Host 'Completely close and reopen Edge, Chrome, and Firefox.' -ForegroundColor Yellow
    Write-Host 'To remove the blocking configuration, run this file with the -Uninstall parameter.' -ForegroundColor Yellow
}
